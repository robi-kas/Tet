# --- Server Configuration ---
PORT=3000
NODE_ENV=production

# --- Database ---
# Leave empty to use SQLite (app.db)
# For Production, use a PostgreSQL connection string:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Web3 RPC Nodes (Required for Payment Verification) ---
VITE_RPC_URL_BSC=https://bsc-dataseed.binance.org/
VITE_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# --- System Contracts ---
# BEP-20 USDT on Binance Smart Chain
VITE_USDT_CONTRACT_BSC=0x55d398326f99059fF775485246999027B3197955
# ERC-20 USDT on Ethereum
VITE_USDT_CONTRACT_MAINNET=0xdAC17F958D2ee523a2206206994597C13D831ec7

# --- Settlement Wallet (Internal Use) ---
# The address that receives the 80U payments
VITE_SYSTEM_WALLET_ADDRESS=0xYourSystemWalletAddress

# --- Security ---
# Secret for signing any session tokens if implemented
SESSION_SECRET=a_very_long_random_string_here
